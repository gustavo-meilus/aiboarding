#!/usr/bin/env bash
# aiboarding PreToolUse[Task] hook: give spawned sub-agents the onboarding doc.
#
# IMPLEMENTATION RISK (verify per installed Claude Code version): the exact
# PreToolUse sub-agent injection mechanism is version-dependent. This script
# uses hookSpecificOutput.additionalContext. If a target CC version does not
# deliver PreToolUse additionalContext to the spawned Task sub-agent, switch to
# the updatedInput mechanism that prepends the doc to the Task prompt. Verified
# manually in Task 6 Step 7.
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/_lib"

resolve_doc_path

# No doc -> nothing to inject; the parent session's SessionStart already handled it.
[ -f "$DOC_PATH" ] || exit 0

if body="$(cat "$DOC_PATH")"; then
  raw="$(printf '<aiboarding-context>\n%s\n</aiboarding-context>' "$body")"
  emit_cc_context "PreToolUse" "$raw"
fi
exit 0
