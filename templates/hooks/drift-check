#!/usr/bin/env bash
# aiboarding PostToolUse hook: nudge on drift since the last onboarding sync.
#
# Wired with `"if": "Bash(git *)"` so the process only spawns after git
# commands. The stdin gate below is defense in depth for Claude Code versions
# that ignore the `if` filter: they get the v0.2.0 behavior (spawn on every
# Bash call, exit silently for non-git commands).
#
# Drift-on-uncertainty stance: an empty pointer, a failed git call, or an
# empty diff range all nudge - silence is reserved for provable in-sync.
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/_lib"

# Stdin self-gate: when hook input is piped and names a non-git command, stop.
if [ ! -t 0 ]; then
  input="$(cat 2>/dev/null || true)"
  if [ -n "$input" ]; then
    case "$input" in
      *'"command"'*git*) : ;;
      *) exit 0 ;;
    esac
  fi
fi

resolve_paths

head_sha="$(git -C "$PROJECT_DIR" rev-parse HEAD 2>/dev/null || echo "")"
[ -n "$head_sha" ] || exit 0

if [ -f "$STATE_PATH" ]; then
  # Modern layout: pointer lives in the .aiboarding/state.json sidecar.
  json_get "$STATE_PATH" "last_synced_commit"
  last="$REPLY"

  nudge=0
  if [ -z "$last" ]; then
    nudge=1   # never-synced or malformed state: nudge as a repair signal
  elif [ "$last" != "$head_sha" ]; then
    changed="$(git -C "$PROJECT_DIR" diff --name-only "$last"..HEAD 2>/dev/null)" || changed=""
    if [ -z "$changed" ]; then
      nudge=1   # git failure (rebased-away pointer) or empty tree delta: ambiguous
    else
      # Onboarding files and configured paths are definitionally not drift.
      ignored=".aiboarding/*
AGENTS.md
CLAUDE.md"
      json_get_array_items "$CONFIG_PATH" "ignored_paths"
      [ -n "$REPLY" ] && ignored="${ignored}
${REPLY}"
      while IFS= read -r f; do
        [ -n "$f" ] || continue
        path_matches_any "$f" "$ignored" || { nudge=1; break; }
      done <<EOF
$changed
EOF
    fi
  fi

  if [ "$nudge" -eq 1 ]; then
    raw="$(printf '<aiboarding-drift>Commits have landed since AGENTS.md was last synced (%s..HEAD). Run the update-agent-onboarding skill to triage whether the onboarding files need updating.</aiboarding-drift>' "$last")"
    emit_cc_context "PostToolUse" "$raw"
  fi
  exit 0
fi

if [ -f "$LEGACY_DOC_PATH" ]; then
  # Legacy layout: pointer still lives inside the committed AIBOARDING.md, so
  # the v0.2.0 doc-only-range suppression must stay (issue #1 would otherwise
  # return). The nudge points at migration.
  read_frontmatter "$LEGACY_DOC_PATH" "last_synced_commit"
  last="$REPLY"

  nudge=0
  if [ -z "$last" ]; then
    nudge=1
  elif [ "$last" != "$head_sha" ]; then
    changed="$(git -C "$PROJECT_DIR" diff --name-only "$last"..HEAD 2>/dev/null)" || changed=""
    if [ -z "$changed" ]; then
      nudge=1
    else
      while IFS= read -r f; do
        [ "$f" = "AIBOARDING.md" ] || { nudge=1; break; }
      done <<EOF
$changed
EOF
    fi
  fi

  if [ "$nudge" -eq 1 ]; then
    raw="$(printf '<aiboarding-drift>Commits have landed since AIBOARDING.md was last synced (%s..HEAD). This repo uses the legacy aiboarding layout - run the migrate-aiboarding skill to move to AGENTS.md + CLAUDE.md, or update-aiboarding to triage the drift.</aiboarding-drift>' "$last")"
    emit_cc_context "PostToolUse" "$raw"
  fi
fi
exit 0
